# InstantDB Configuration
# Get your app ID from https://instantdb.com/dash
VITE_INSTANT_APP_ID=your_instant_app_id_here

# Resend API (for sending invitation emails)
# Get your API key from https://resend.com/api-keys
# Required for production deployment
RESEND_API_KEY=re_your_resend_api_key_here

# LinkedIn OAuth (optional - for future publish feature)
VITE_LINKEDIN_CLIENT_ID=your_client_id_here
LINKEDIN_CLIENT_SECRET=your_client_secret_here

# Anthropic API (optional - for Ambient Coach feature)
# Note: ANTHROPIC_API_KEY is used by Vite dev server proxy, NOT exposed to browser
ANTHROPIC_API_KEY=your_anthropic_key_here
