# Hemingway Ambient Coach — Environment Variables
#
# Copy this file to .env.local before running `npm run dev`.
#   cp .env.example .env.local
#
# IMPORTANT: Copy to .env.local, NOT .env
# .env.local is gitignored (via *.local in .gitignore).
# .env is NOT gitignored on this branch — a bare .env would be committed.


# ─── Anthropic API (Vite dev-server proxy) ────────────────────────────────────
#
# Used by the Vite dev-server proxy (server-side Node.js context) to forward
# POST /api/coach → Anthropic API. This key is NEVER exposed to browser bundles.
#
# The proxy only exists during `npm run dev`. It does not exist in production
# builds or the Electron app. Coaching is intentionally dev-only for this phase.
#
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here


# ─── WARNING: Do NOT use VITE_ANTHROPIC_API_KEY ───────────────────────────────
#
# The VITE_ prefix causes Vite to embed variables into browser bundles at build
# time. Using VITE_ANTHROPIC_API_KEY would expose your secret key to anyone who
# downloads your app or inspects the JS bundle.
#
# This entry exists ONLY as a warning. It is not used anywhere in the codebase.
# Do not add VITE_ANTHROPIC_API_KEY to your .env.local or any code.
#
# VITE_ANTHROPIC_API_KEY=DO_NOT_USE_THIS


# ─── LinkedIn OAuth (optional) ────────────────────────────────────────────────
#
# Required only if you want to use the LinkedIn publish feature.
# VITE_ prefix is correct here — the client ID is public (safe for browser).
# The client secret is server-side only (no VITE_ prefix).
#
# VITE_LINKEDIN_CLIENT_ID=your_linkedin_client_id
# LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
